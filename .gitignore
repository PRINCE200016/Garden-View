# =============================================
# Garden View Resort - .gitignore
# =============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
target/

# Environment variables - NEVER commit these!
.env
.env.local
.env.production
*.env

# IDE
.vscode/
.idea/
*.iml

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# Java
*.class
*.jar
*.war
*.ear
*.zip
*.tar.gz
hs_err_pid*

# Maven
.mvn/wrapper/maven-wrapper.jar

# Spring Boot
spring-boot-*.log

# H2 database files (if file-based)
*.db
*.mv.db
*.trace.db
