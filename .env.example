# ============================================
# Garden View Resort - Frontend Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# For local development (backend running locally):
# VITE_API_URL=http://localhost:8081

# For production (Hugging Face Space URL):
# Example: https://YOUR-USERNAME-garden-view-resort.hf.space
# Since API calls will be made from the browser, make sure the URL
# does not end with a trailing slash!
VITE_API_URL=https://your-huggingface-space-url.hf.space
